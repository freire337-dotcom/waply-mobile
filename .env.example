# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio_muy_seguro

# ── Super Admin (para crear tenants) ─────────────────────────────────────────
SUPER_ADMIN_TOKEN=otro_token_secreto_para_operaciones_de_superadmin

# ── Entorno ───────────────────────────────────────────────────────────────────
NODE_ENV=development   # production en producción

# ── Nota: las credenciales de WhatsApp y FCM se configuran POR TENANT ─────────
# No hay variables WA_ ni FCM_ globales.
# Cada tenant guarda su wa_phone_id, wa_token, wa_verify_token y fcm_server_key
# en la tabla tenants de la BD.
# Se configuran vía PATCH /api/tenants/:id o al crear el tenant.

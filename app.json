{
  "expo": {
    "name": "Waply",
    "slug": "whasat",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#075E54"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tuempresa.whasat"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#075E54"
      },
      "package": "com.tuempresa.whasat",
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#075E54"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Waply necesita acceso a tus fotos para enviarlas en el chat.",
          "cameraPermission": "Waply necesita acceso a la cámara para enviar fotos en el chat."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Waply necesita acceso al micrófono para grabar notas de voz."
        }
      ]
    ],
    "scheme": "whasat",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "171f4690-167b-4f58-a10f-a0eb613dbe76"
      }
    }
  }
}
